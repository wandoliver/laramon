{
    "name": "laramon/agent",
    "description": "Monitoring agent that ships Laravel Pulse aggregates and business metrics to a LaraMon hub.",
    "license": "MIT",
    "type": "library",
    "keywords": ["laravel", "monitoring", "pulse", "observability"],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "laravel/pulse": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "LaraMon\\Agent\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraMon\\Agent\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraMon\\Agent\\MonitorAgentServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
